---
import Layout from '../layouts/Layout.astro'
import SiteHeader from '../components/SiteHeader.astro'
const base = import.meta.env.BASE_URL
---

<Layout title="PokeBasic — Stats Explorer" description="Rank and compare all 1025 Pokémon by any base stat. Filter by type and generation, sort by BST, HP, Attack, Defense, and more.">
    <SiteHeader subtitle="Stats Explorer" activeRoute="/stats" />
<div x-data="statsRanking">

    <main class="max-w-7xl mx-auto px-4 py-6">

        <!-- ══════════ PAGE TITLE ══════════ -->
        <div class="mb-6">
            <h1 class="text-2xl font-black text-slate-800 mb-1">📊 Stats Explorer</h1>
            <p class="text-sm text-slate-400 font-medium">Rank Pokémon by BST, HP, Attack, and more. Filter by type and generation. "All" loads all 1025 Pokémon progressively.</p>
        </div>

        <!-- ══════════ TYPE SELECTOR ══════════ -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 mb-5">
            <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-3">Filter by Type</p>
            <div class="flex flex-wrap gap-2">
                <button @click="selectType('all')"
                    :class="selectedType === 'all' ? 'ring-2 ring-violet-500 ring-offset-1 opacity-100' : 'opacity-60 hover:opacity-90'"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-full font-bold text-xs text-white transition"
                    style="background: linear-gradient(135deg, #7c3aed, #4c08ef)">
                    ✦ All
                </button>
                <template x-for="type in typeList" :key="type">
                    <button @click="selectType(type)"
                        :class="selectedType === type ? 'ring-2 ring-offset-1 opacity-100' : 'opacity-60 hover:opacity-90'"
                        :style="`background: linear-gradient(135deg, ${typeColor(type)}, ${typeColor(type)}cc); --tw-ring-color: ${typeColor(type)}`"
                        class="flex items-center gap-1.5 px-3 py-1.5 rounded-full font-bold text-xs text-white transition">
                        <img :src="typeIconUrl(type)" class="w-3 h-3" style="filter:brightness(0) invert(1)">
                        <span x-text="type.charAt(0).toUpperCase() + type.slice(1)"></span>
                    </button>
                </template>
            </div>
        </div>

        <!-- ══════════ GEN FILTER ══════════ -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 mb-5">
            <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-3">Filter by Generation</p>
            <div class="flex flex-wrap gap-2">
                <button @click="resetGens()"
                    :class="allGensActive() ? 'bg-violet-600 text-white border-violet-600 hover:bg-violet-700 hover:border-violet-700 shadow-sm shadow-violet-200' : 'bg-white text-slate-500 border-slate-200 hover:bg-violet-50 hover:border-violet-400 hover:text-violet-700'"
                    class="px-3 py-1.5 rounded-full text-xs font-black border transition-all duration-150 hover:scale-105 active:scale-95">All</button>
                <template x-for="(label, i) in genLabels" :key="i">
                    <button @click="toggleGen(gens[i])"
                        :class="isGenActive(gens[i]) ? 'bg-violet-600 text-white border-violet-600 hover:bg-violet-700 hover:border-violet-700 shadow-sm shadow-violet-200' : 'bg-white text-slate-500 border-slate-200 hover:bg-violet-50 hover:border-violet-400 hover:text-violet-700'"
                        class="px-3 py-1.5 rounded-full text-xs font-black border transition-all duration-150 hover:scale-105 active:scale-95"
                        x-text="'Gen ' + label"></button>
                </template>
            </div>
        </div>

        <!-- ══════════ CONTROLS ══════════ -->
        <div x-show="loaded.length > 0 || loading" class="bg-white rounded-2xl border border-slate-200 shadow-sm p-4 mb-4 flex flex-wrap items-center gap-3">
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Sort by</span>
            <template x-for="opt in sortOptions" :key="opt.key">
                <button @click="setSort(opt.key)" :class="sortKey === opt.key ? 'fchip-active' : ''" class="fchip" x-text="opt.label"></button>
            </template>
            <div class="ml-auto relative">
                <img src={`${base}/search.svg`} alt="Search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 pointer-events-none">
                <input type="text" x-model="searchQuery" @input="page = 0" placeholder="Filter by name…"
                    class="pl-8 pr-3 py-1.5 text-xs border-2 border-slate-200 rounded-lg focus:outline-none focus:border-violet-400 font-semibold bg-slate-50 w-44">
            </div>
        </div>

        <!-- ══════════ LOADING STATE ══════════ -->
        <div x-show="loading" class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8 mb-4 text-center">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-violet-600 mx-auto mb-4"></div>
            <p class="text-slate-500 font-semibold text-sm mb-3" x-text="loadingText"></p>
            <div x-show="loadingProgress > 0" class="max-w-xs mx-auto">
                <div class="flex items-center justify-between mb-1">
                    <span class="text-xs text-slate-400">Progress</span>
                    <span class="text-xs font-bold text-violet-600" x-text="loadingProgress + '%'"></span>
                </div>
                <div class="h-2 bg-slate-200 rounded-full overflow-hidden">
                    <div class="h-full bg-violet-500 rounded-full transition-all duration-300" :style="`width:${loadingProgress}%`"></div>
                </div>
            </div>
        </div>

        <!-- ══════════ EMPTY STATE ══════════ -->
        <div x-show="!loading && loaded.length === 0 && selectedType === ''"
            class="bg-white rounded-2xl border border-slate-200 shadow-sm p-12 text-center">
            <div class="text-5xl mb-4">📊</div>
            <h2 class="text-lg font-black text-slate-700 mb-2">Select a type to begin</h2>
            <p class="text-sm text-slate-400 max-w-sm mx-auto">Pick any type above to rank Pokémon by any base stat. Choose <strong>"All"</strong> to compare across all 1025 Pokémon.</p>
        </div>

        <!-- ══════════ NO RESULTS ══════════ -->
        <div x-show="!loading && loaded.length > 0 && sortedFiltered.length === 0"
            class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8 text-center">
            <p class="text-slate-400 font-semibold">No Pokémon match "<span x-text="searchQuery"></span>"</p>
        </div>

        <!-- ══════════ RESULTS ══════════ -->
        <div x-show="!loading && sortedFiltered.length > 0">
            <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                <p class="text-sm text-slate-500 font-semibold">
                    <strong x-text="sortedFiltered.length" class="text-slate-700"></strong>
                    Pokémon ·
                    <span x-text="'Page ' + (page + 1) + ' of ' + totalPages"></span>
                </p>
                <div class="flex items-center gap-2" x-show="totalPages > 1">
                    <button @click="prevPage()" :disabled="page === 0"
                        class="px-3 py-1.5 rounded-lg bg-white border border-slate-200 text-xs font-bold text-slate-600 hover:border-violet-400 disabled:opacity-30 transition">← Prev</button>
                    <span class="text-xs text-slate-400 font-semibold" x-text="(page + 1) + ' / ' + totalPages"></span>
                    <button @click="nextPage()" :disabled="page >= totalPages - 1"
                        class="px-3 py-1.5 rounded-lg bg-white border border-slate-200 text-xs font-bold text-slate-600 hover:border-violet-400 disabled:opacity-30 transition">Next →</button>
                </div>
            </div>

            <div class="space-y-1.5">
                <template x-for="(p, idx) in pageItems" :key="p.id">
                    <div class="bg-white rounded-xl border border-slate-200 p-3 flex items-center gap-3 hover:border-violet-300 hover:shadow-sm transition group">
                        <span class="text-sm font-black text-slate-300 w-7 text-right shrink-0" x-text="startRank + idx"></span>
                        <img :src="`https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${p.id}.png`"
                            :alt="p.name" loading="lazy" class="w-12 h-12 object-contain shrink-0" style="image-rendering:pixelated">
                        <div class="w-48 min-w-0 shrink-0">
                            <button @click="window.openPokemonQuickView(p.name)"
                                class="font-black text-sm text-slate-800 capitalize hover:text-violet-600 transition text-left cursor-pointer"
                                x-text="capitalize(p.name)"></button>
                            <div class="flex gap-1 flex-wrap mt-0.5">
                                <template x-for="t in getPokemonTypes(p)" :key="t">
                                    <span x-html="typeBadgeHtml(t)"></span>
                                </template>
                            </div>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 mb-1">
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-wide w-6 shrink-0" x-text="STAT_LABELS[sortKey] ?? sortKey.toUpperCase()"></span>
                                <div class="flex-1 h-2.5 bg-slate-100 rounded-full overflow-hidden">
                                    <div class="h-full rounded-full transition-all duration-500"
                                        :style="`width:${Math.min(100, Math.round(getStatVal(p, sortKey) / (sortKey === 'bst' ? 720 : 255) * 100))}%;background:${STAT_COLORS[sortKey] ?? '#8b5cf6'}`"></div>
                                </div>
                                <span class="text-sm font-black w-8 shrink-0"
                                    :class="getStatVal(p, sortKey) >= 120 ? 'text-violet-600' : getStatVal(p, sortKey) >= 90 ? 'text-blue-500' : 'text-slate-700'"
                                    x-text="getStatVal(p, sortKey)"></span>
                                <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full hidden sm:inline"
                                    :style="`background:${speedTier(getStatVal(p, 'speed')).color}22;color:${speedTier(getStatVal(p, 'speed')).color}`"
                                    x-show="sortKey === 'speed'"
                                    x-text="speedTier(getStatVal(p, 'speed')).label"></span>
                            </div>
                            <div class="flex gap-3 flex-wrap">
                                <template x-for="sk in ['hp','attack','special-attack','defense','special-defense','speed'].filter(k => k !== sortKey)" :key="sk">
                                    <span class="text-[10px] text-slate-400 font-semibold">
                                        <span class="font-black" :style="`color:${STAT_COLORS[sk]}`" x-text="STAT_LABELS[sk]"></span>
                                        <span x-text="' ' + getStatVal(p, sk)"></span>
                                    </span>
                                </template>
                                <span class="text-[10px] text-slate-400 font-semibold" x-show="sortKey !== 'bst'">
                                    <span class="font-black text-violet-500">BST</span>
                                    <span x-text="' ' + getStatVal(p, 'bst')"></span>
                                </span>
                            </div>
                        </div>
                    </div>
                </template>
            </div>

            <div class="flex items-center justify-center gap-3 mt-5" x-show="totalPages > 1">
                <button @click="prevPage()" :disabled="page === 0"
                    class="px-4 py-2 rounded-lg bg-white border border-slate-200 text-sm font-bold text-slate-600 hover:border-violet-400 disabled:opacity-30 transition">← Prev</button>
                <span class="text-sm text-slate-500 font-semibold" x-text="'Page ' + (page + 1) + ' of ' + totalPages"></span>
                <button @click="nextPage()" :disabled="page >= totalPages - 1"
                    class="px-4 py-2 rounded-lg bg-white border border-slate-200 text-sm font-bold text-slate-600 hover:border-violet-400 disabled:opacity-30 transition">Next →</button>
            </div>
        </div>

    </main>

    <!-- ══════════ STATS POKEMON MODAL ══════════ -->
    <div x-data="statsPokemonModal">
        <div x-show="open" style="display:none"
            class="fixed inset-0 z-50 flex items-center justify-center p-4"
            @keydown.escape.window="closeModal()">
            <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" @click="closeModal()"></div>
            <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm max-h-[90vh] overflow-y-auto z-10">
                <div x-show="loading" class="p-12 text-center">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-violet-600 mx-auto mb-3"></div>
                    <p class="text-slate-400 text-sm font-semibold">Loading…</p>
                </div>
                <div x-show="!loading && pokemon">
                    <div class="rounded-t-2xl p-5 relative" :style="{ background: bannerColor }">
                        <button @click="closeModal()" class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full bg-white/20 hover:bg-white/30 text-white font-bold transition text-sm">✕</button>
                        <div class="flex items-end gap-3">
                            <img :src="pokemon?.sprites?.other?.['official-artwork']?.front_default ?? pokemon?.sprites?.front_default ?? ''"
                                :alt="pokemon?.name"
                                class="w-28 h-28 object-contain shrink-0"
                                style="filter:drop-shadow(0 4px 12px rgba(0,0,0,0.35))">
                            <div class="pb-1">
                                <p class="text-white/60 text-[11px] font-bold mb-0.5">#<span x-text="String(pokemon?.id ?? '').padStart(4, '0')"></span></p>
                                <h2 class="font-black text-lg text-white leading-tight capitalize" x-text="pokemon?.name?.replace(/-/g, ' ')"></h2>
                                <div class="flex gap-1 flex-wrap mt-1.5" x-html="typeBadgesHtml"></div>
                                <span x-show="generation"
                                    class="mt-1.5 inline-block text-[10px] font-black tracking-widest text-white/80 bg-white/20 px-2 py-0.5 rounded-full uppercase"
                                    x-text="generation"></span>
                            </div>
                        </div>
                    </div>
                    <div class="p-5">
                        <div class="flex items-center gap-2 mb-4">
                            <span class="text-xs font-black px-2.5 py-1 rounded-full"
                                :style="{ background: speedTier(speed).color + '22', color: speedTier(speed).color }"
                                x-text="speedTier(speed).label"></span>
                            <span class="text-xs text-slate-400 font-semibold">BST <strong class="text-slate-700" x-text="bst"></strong></span>
                        </div>
                        <div class="space-y-2 mb-4">
                            <template x-for="stat in stats" :key="stat.label">
                                <div class="flex items-center gap-2">
                                    <span class="text-[10px] font-black w-8 shrink-0" :style="{ color: stat.color }" x-text="stat.label"></span>
                                    <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                                        <div class="h-full rounded-full transition-all duration-500" :style="{ width: stat.pct + '%', background: stat.color }"></div>
                                    </div>
                                    <span class="text-xs font-bold text-slate-700 w-7 text-right shrink-0" x-text="stat.value"></span>
                                </div>
                            </template>
                        </div>
                        <p x-show="flavorText" class="text-xs text-slate-400 italic leading-relaxed mb-4" x-text="flavorText"></p>
                        <button @click="goToPokedex(pokemon?.name ?? '')"
                            class="w-full py-2.5 bg-violet-600 hover:bg-violet-700 text-white font-bold text-sm rounded-xl transition">
                            Open full Pokédex →
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
</Layout>
